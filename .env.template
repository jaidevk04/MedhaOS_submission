# ============================================
# MedhaOS Backend Configuration Template
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# 1. API KEYS (REQUIRED)
# ============================================

# Gemini API Key (Get from: https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini API Configuration
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048

# ============================================
# 2. DATABASE CONFIGURATION
# ============================================

# PostgreSQL (Already configured in docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medhaos_db
DB_USER=medhaos
DB_PASSWORD=medhaos_dev_password

# Redis (Already configured in docker-compose)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# 3. FACILITY INFORMATION (REQUIRED)
# ============================================

FACILITY_NAME=Your Hospital Name
FACILITY_TYPE=hospital
FACILITY_CITY=Mumbai
FACILITY_STATE=Maharashtra
FACILITY_COUNTRY=India
FACILITY_TOTAL_BEDS=100
FACILITY_ICU_BEDS=20
FACILITY_EMERGENCY_BEDS=10

# ============================================
# 4. APPLICATION SETTINGS
# ============================================

# Server Configuration
NODE_ENV=development
PORT=4000
API_VERSION=v1

# JWT Configuration
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRY=24h

# Session Configuration
SESSION_SECRET=your_session_secret_change_in_production
SESSION_TIMEOUT_HOURS=24

# ============================================
# 5. LANGUAGE SETTINGS
# ============================================

PRIMARY_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi,ta,te,mr

# ============================================
# 6. BUSINESS RULES
# ============================================

# Appointment Settings
APPOINTMENT_SLOT_DURATION_MINUTES=30
APPOINTMENT_BUFFER_MINUTES=5
APPOINTMENT_ALLOW_OVERBOOKING=false
APPOINTMENT_ADVANCE_BOOKING_DAYS=30

# Triage Settings
TRIAGE_CRITICAL_THRESHOLD=70
TRIAGE_URGENT_THRESHOLD=40
TRIAGE_CONFIDENCE_THRESHOLD=0.75

# AI Confidence Thresholds
AI_AUTONOMOUS_THRESHOLD=0.85
AI_REVIEW_THRESHOLD=0.75
AI_ESCALATE_THRESHOLD=0.60

# ============================================
# 7. WORKING HOURS
# ============================================

OPD_WEEKDAY_HOURS=09:00-17:00
OPD_SATURDAY_HOURS=09:00-13:00
OPD_SUNDAY_HOURS=closed
EMERGENCY_HOURS=24/7

# ============================================
# 8. TIMEZONE
# ============================================

TIMEZONE=Asia/Kolkata

# ============================================
# 9. OPTIONAL INTEGRATIONS
# ============================================

# ABDM (India Digital Health)
ABDM_ENABLED=false
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_BASE_URL=https://dev.abdm.gov.in

# Bhashini (Multilingual Speech)
BHASHINI_ENABLED=false
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_BASE_URL=https://dhruva-api.bhashini.gov.in

# Twilio (SMS Notifications)
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp Business API
WHATSAPP_ENABLED=false
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# ============================================
# 10. SECURITY & COMPLIANCE
# ============================================

# Data Retention (in years)
DATA_RETENTION_PATIENT_RECORDS=7
DATA_RETENTION_AUDIT_LOGS=3
DATA_RETENTION_MEDICAL_IMAGES=7

# Compliance
DISHA_ACT_COMPLIANCE=true
DATA_RESIDENCY=india
ENCRYPTION_AT_REST=true
ENCRYPTION_IN_TRANSIT=true

# ============================================
# 11. MONITORING & LOGGING
# ============================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ENABLED=true
GRAFANA_PORT=3001

# ============================================
# 12. RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# ============================================
# 13. CORS CONFIGURATION
# ============================================

CORS_ORIGIN=http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# ============================================
# 14. FILE UPLOAD
# ============================================

MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# ============================================
# 15. DEPLOYMENT
# ============================================

DEPLOYMENT_ENV=local
CLOUD_PROVIDER=
CLOUD_REGION=

# ============================================
# END OF CONFIGURATION
# ============================================

# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://medhaos:medhaos_dev_password@localhost:5432/medhaos_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# AWS Configuration (LocalStack for local development)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT=http://localhost:4566
USE_LOCALSTACK=true

# S3 / Minio
S3_BUCKET=medhaos-storage
S3_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# DynamoDB
DYNAMODB_TABLE_PREFIX=medhaos-dev

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# ABDM Integration
ABDM_API_URL=https://sandbox.abdm.gov.in
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=

# Bhashini API
BHASHINI_API_URL=https://bhashini.gov.in/api
BHASHINI_API_KEY=
BHASHINI_USER_ID=

# AI Models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AWS_BEDROCK_REGION=us-east-1

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Feature Flags
ENABLE_AMBIENT_SCRIBE=true
ENABLE_VISION_AGENT=true
ENABLE_OFFLINE_MODE=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key
FIELD_ENCRYPTION_KEY=your-field-level-encryption-key

# Notification Services
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
WHATSAPP_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Analytics
MIXPANEL_TOKEN=
AMPLITUDE_API_KEY=

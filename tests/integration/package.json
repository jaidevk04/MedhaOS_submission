{
  "name": "@medhaos/integration-tests",
  "version": "1.0.0",
  "description": "Integration tests for MedhaOS Healthcare Intelligence Ecosystem",
  "private": true,
  "scripts": {
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:patient-journey": "jest --config jest.config.js patient-journey",
    "test:multi-agent": "jest --config jest.config.js multi-agent",
    "test:external": "jest --config jest.config.js external-integrations",
    "test:performance": "jest --config jest.config.js performance",
    "setup:test-env": "docker-compose -f docker-compose.test.yml up -d",
    "teardown:test-env": "docker-compose -f docker-compose.test.yml down -v"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "axios": "^1.6.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}

{
  "name": "@medhaos/e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for MedhaOS Healthcare Intelligence Ecosystem",
  "private": true,
  "scripts": {
    "test:e2e:web": "playwright test",
    "test:e2e:web:ui": "playwright test --ui",
    "test:e2e:web:debug": "playwright test --debug",
    "test:e2e:android": "jest --config jest.mobile.config.js --testPathPattern=android",
    "test:e2e:ios": "jest --config jest.mobile.config.js --testPathPattern=ios",
    "test:e2e:all": "npm run test:e2e:web && npm run test:e2e:android",
    "playwright:install": "playwright install --with-deps",
    "appium:start": "appium --allow-insecure chromedriver_autodownload",
    "update:snapshots": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@faker-js/faker": "^8.3.0",
    "webdriverio": "^8.27.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@wdio/types": "^8.27.0",
    "appium": "^2.4.0",
    "appium-uiautomator2-driver": "^2.34.0",
    "appium-xcuitest-driver": "^5.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Auth Service
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3001

# Feature Flags
NEXT_PUBLIC_ENABLE_AMBIENT_SCRIBE=true
NEXT_PUBLIC_ENABLE_CDSS=true
NEXT_PUBLIC_ENABLE_DRUG_SAFETY=true

# Environment
NODE_ENV=development

{
  "name": "@medhaos/database",
  "version": "1.0.0",
  "description": "Database schema and client for MedhaOS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "dynamodb:setup": "tsx scripts/setup-dynamodb.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.999.0",
    "@aws-sdk/lib-dynamodb": "^3.999.0",
    "@prisma/client": "^5.9.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.9.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}

# Database Connection
DATABASE_URL="postgresql://medhaos:medhaos_dev_password@localhost:5432/medhaos_db?schema=public"

# Connection Pool Settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT=10000

# Query Logging
DATABASE_LOG_QUERIES=true

# DynamoDB Configuration
AWS_REGION=ap-south-1
DYNAMODB_ENDPOINT=http://localhost:4566
DYNAMODB_TABLE_AGENT_TASKS=medhaos-agent-tasks
DYNAMODB_TABLE_SESSION_DATA=medhaos-session-data
DYNAMODB_TABLE_QUEUE_MANAGEMENT=medhaos-queue-management

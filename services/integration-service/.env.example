# Server Configuration
PORT=3020
NODE_ENV=development

# ABDM Configuration
ABDM_BASE_URL=https://healthidsbx.abdm.gov.in
ABDM_CLIENT_ID=your_abdm_client_id
ABDM_CLIENT_SECRET=your_abdm_client_secret
ABDM_REDIRECT_URI=https://your-app.com/abdm/callback

# EHR System Configuration
EHR_FHIR_BASE_URL=https://ehr-system.example.com/fhir
EHR_CLIENT_CERT_PATH=/path/to/client-cert.pem
EHR_CLIENT_KEY_PATH=/path/to/client-key.pem
EHR_CA_CERT_PATH=/path/to/ca-cert.pem

# LIS Configuration
LIS_BASE_URL=https://lis-system.example.com/api
LIS_API_KEY=your_lis_api_key
LIS_HL7_HOST=lis-hl7.example.com
LIS_HL7_PORT=2575

# PACS Configuration
PACS_AE_TITLE=MEDHAOS_PACS
PACS_HOST=pacs.example.com
PACS_PORT=11112
PACS_CALLING_AE_TITLE=MEDHAOS
PACS_S3_BUCKET=medhaos-dicom-images

# AWS SNS Configuration
AWS_REGION=ap-south-1
AWS_SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:medhaos-notifications

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Business API Configuration
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
EMAIL_FROM=noreply@medhaos.health

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/medhaos

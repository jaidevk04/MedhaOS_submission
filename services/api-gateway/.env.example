# API Gateway Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Service URLs
AUTH_SERVICE_URL=http://localhost:3001
TRIAGE_SERVICE_URL=http://localhost:3002
CDSS_SERVICE_URL=http://localhost:3003
DRUG_SAFETY_SERVICE_URL=http://localhost:3004
DIAGNOSTIC_VISION_SERVICE_URL=http://localhost:3005
OPERATIONAL_INTELLIGENCE_SERVICE_URL=http://localhost:3006
NURSE_TASK_SERVICE_URL=http://localhost:3007
SUPPLY_CHAIN_SERVICE_URL=http://localhost:3008
REVENUE_CYCLE_SERVICE_URL=http://localhost:3009
PUBLIC_HEALTH_SERVICE_URL=http://localhost:3010
POST_DISCHARGE_SERVICE_URL=http://localhost:3011
INTEGRATION_SERVICE_URL=http://localhost:3012
EDGE_INTELLIGENCE_SERVICE_URL=http://localhost:3013
SUPERVISOR_SERVICE_URL=http://localhost:3014
AMBIENT_SCRIBE_SERVICE_URL=http://localhost:3015
SPEECH_NLP_SERVICE_URL=http://localhost:3016
QUEUE_OPTIMIZATION_SERVICE_URL=http://localhost:3017

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/medhaos

# Redis Cache
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Logging
LOG_LEVEL=info

# API Documentation
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs

# GraphQL
GRAPHQL_ENABLED=true
GRAPHQL_PATH=/graphql
GRAPHQL_PLAYGROUND=true

# WebSocket
WEBSOCKET_ENABLED=true
WEBSOCKET_PATH=/ws

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Server Configuration
PORT=3012
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/medhaos

# DynamoDB Configuration (for real-time task data)
AWS_REGION=ap-south-1
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TASKS_TABLE=nurse-tasks
DYNAMODB_WORKLOAD_TABLE=nurse-workload

# WebSocket Configuration
WS_PORT=3013

# Task Router Configuration
MAX_NURSE_WORKLOAD=8
TASK_REDISTRIBUTION_THRESHOLD=7
CRITICAL_TASK_PRIORITY=100
URGENT_TASK_PRIORITY=75
ROUTINE_TASK_PRIORITY=50

# Alert Configuration
OVERLOAD_ALERT_THRESHOLD=8
ESCALATION_TIMEOUT_MINUTES=5

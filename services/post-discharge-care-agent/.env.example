# Server Configuration
PORT=3017
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/medhaos

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# AWS Polly (Text-to-Speech)
POLLY_VOICE_ID_HINDI=Aditi
POLLY_VOICE_ID_ENGLISH=Joanna
POLLY_VOICE_ID_TAMIL=Kajal
POLLY_VOICE_ID_KANNADA=Kajal

# AWS SNS (Notifications)
SNS_TOPIC_ARN_SMS=arn:aws:sns:ap-south-1:123456789012:patient-notifications
SNS_TOPIC_ARN_WHATSAPP=arn:aws:sns:ap-south-1:123456789012:whatsapp-notifications

# AWS S3 (Storage)
S3_BUCKET_NAME=medhaos-patient-content
S3_MEDICATION_IMAGES_BUCKET=medhaos-medication-images
S3_BUCKET_REGION=ap-south-1

# AWS Rekognition (Image Recognition)
REKOGNITION_COLLECTION_ID=medication-pills

# Twilio (Optional - for voice calls)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Business API
WHATSAPP_API_URL=https://api.whatsapp.com/v1
WHATSAPP_API_KEY=your_api_key

# Medication Reminder Configuration
REMINDER_CHECK_INTERVAL_MINUTES=5
REMINDER_ADVANCE_MINUTES=30
MAX_REMINDER_ATTEMPTS=3

# Medication Verification Configuration
MEDICATION_VERIFICATION_MIN_CONFIDENCE=70
MAX_IMAGE_SIZE_MB=10
SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png

# Follow-up Configuration
FOLLOWUP_DAY_7_ENABLED=true
FOLLOWUP_DAY_14_ENABLED=true
FOLLOWUP_DAY_30_ENABLED=true
FOLLOWUP_CALL_RETRY_ATTEMPTS=3

# Symptom Escalation
ESCALATION_KEYWORDS=fever,bleeding,severe pain,chest pain,difficulty breathing,confusion
ESCALATION_PHONE_NUMBER=+911234567890

# Content Delivery
VIDEO_CDN_URL=https://cdn.medhaos.com/videos
CONTENT_LANGUAGES=en,hi,ta,kn,te,ml,bn,mr,gu,pa,or,as

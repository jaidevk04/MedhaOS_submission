# Server Configuration
PORT=3010
NODE_ENV=development
SERVICE_NAME=cdss-agent
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medhaos

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Bedrock Configuration (for LLM)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Pinecone Configuration (Vector Database)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=medhaos-medical-knowledge

# PubMed API
PUBMED_API_KEY=your_pubmed_api_key
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# Clinical Trials API
CLINICAL_TRIALS_API_URL=https://clinicaltrials.gov/api/v2

# NMC Guidelines Repository
NMC_GUIDELINES_URL=https://api.nmc.org.in/guidelines

# Server Configuration
PORT=3003
NODE_ENV=development

# Bhashini API Configuration
BHASHINI_API_URL=https://meity-auth.ulcacontrib.org/ulca/apis/v0/model
BHASHINI_API_KEY=your_bhashini_api_key_here
BHASHINI_USER_ID=your_user_id_here

# AWS Configuration (for fallback)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Service Configuration
MAX_AUDIO_SIZE_MB=10
SUPPORTED_LANGUAGES=hi,en,ta,te,kn,ml,bn,gu,mr,pa,or,as,ur,sa,ks,ne,sd,kok,mai,doi,mni,sat
DEFAULT_LANGUAGE=hi

# Server Configuration
PORT=3012
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/medhaos

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Model Configuration
BED_OCCUPANCY_MODEL_ENDPOINT=bed-occupancy-model
ICU_DEMAND_MODEL_ENDPOINT=icu-demand-model
STAFF_SCHEDULING_MODEL_ENDPOINT=staff-scheduling-model

# Prediction Configuration
BED_FORECAST_HORIZON_HOURS=72
ICU_FORECAST_HORIZON_HOURS=24
CAPACITY_ALERT_THRESHOLD=0.8
BURNOUT_RISK_THRESHOLD=0.7

# Logging
LOG_LEVEL=info

# Server Configuration
PORT=3015
NODE_ENV=development
SERVICE_NAME=revenue-cycle-agent
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medhaos

# AI Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key
AWS_BEDROCK_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Medical Coding Configuration
ICD10_VERSION=2024
CPT_VERSION=2024
CODING_CONFIDENCE_THRESHOLD=0.85

# Insurance Configuration
INSURANCE_PAYER_API_URL=https://api.insurance-payer.example.com
INSURANCE_API_KEY=your_insurance_api_key

# Claim Submission
CLAIM_SUBMISSION_ENDPOINT=https://claims.example.com/api/v1
CLAIM_RETRY_ATTEMPTS=3
CLAIM_TIMEOUT_MS=30000

# Prior Authorization
PRIOR_AUTH_ENDPOINT=https://prior-auth.example.com/api/v1
PRIOR_AUTH_TIMEOUT_MS=60000

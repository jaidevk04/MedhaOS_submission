# Server Configuration
PORT=3011
NODE_ENV=development
SERVICE_NAME=diagnostic-vision-agent
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medhaos

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# S3 Configuration (Medical Image Storage)
S3_BUCKET_NAME=medhaos-medical-images
S3_BUCKET_REGION=ap-south-1
S3_PRESIGNED_URL_EXPIRY=3600

# SageMaker Configuration (Vision Models)
SAGEMAKER_LLAVA_ENDPOINT=medhaos-llava-endpoint
SAGEMAKER_BIOMEDCLIP_ENDPOINT=medhaos-biomedclip-endpoint
SAGEMAKER_MEDSAM_ENDPOINT=medhaos-medsam-endpoint

# Bedrock Configuration (for report generation)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# DICOM Server Configuration
DICOM_SERVER_HOST=localhost
DICOM_SERVER_PORT=11112
DICOM_AE_TITLE=MEDHAOS_VLM

# Image Processing Configuration
MAX_IMAGE_SIZE_MB=50
SUPPORTED_FORMATS=jpg,jpeg,png,dcm,dicom
IMAGE_QUALITY=90
THUMBNAIL_SIZE=256

# Model Configuration
CONFIDENCE_THRESHOLD=0.75
CRITICAL_FINDING_THRESHOLD=0.85
MAX_PROCESSING_TIME_SECONDS=8
